  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "openai": "^4.0.0",
    "@google/generative-ai": "^0.21.0",
    "groq-sdk": "^0.3.0",
    "ai": "^4.0.0",
    "@google-cloud/vertexai": "^1.10.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1026.0",
    "@mistralai/mistralai": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlawb.com/z6MkqDnb7Siv3Cwj7pGJq4T5EsUisECqR8KpnDLwcaZq5TPr/hawk"
