{
  "name": "@hawk/eyrie",
  "version": "1.1.0",
  "description": "Eyrie provider runtime and model catalog for Hawk (OpenAI, OpenRouter, Anthropic, Grok/xAI, Gemini, Ollama)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/client/factory/*.test.js dist/config/openaiCompatibleRuntime/*.test.js",
    "ci": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "openai": "^6.33.0",
    "@google/generative-ai": "^0.24.1",
    "groq-sdk": "^1.1.2",
    "ai": "^6.0.151",
    "@google-cloud/vertexai": "^1.10.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1026.0",
    "@mistralai/mistralai": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlawb.com/z6MkqDnb7Siv3Cwj7pGJq4T5EsUisECqR8KpnDLwcaZq5TPr/hawk"
  },
  "keywords": [
    "hawk",
    "llm",
    "api",
    "openai",
    "openrouter",
    "anthropic",
    "grok",
    "gemini",
    "ollama"
  ],
  "license": "MIT"
}
