{
  "name": "@hawk/eyrie",
  "version": "1.0.1",
  "description": "🦅 Universal LLM client - wrapper for OpenAI, Anthropic, Gemini, Mistral, Groq and 50+ providers via baseUrl",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
